{
  "name": "whatsapp-bot",
  "version": "0.1.0",
  "description": "WhatsAppBot intelligence backend for sales simulation with OpenAI and Meta WhatsApp Cloud API.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test:send": "tsx src/scripts/sendTestMessage.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "openai": "^4.79.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
